{
  "name": "enterprise-hris",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise HRIS Platform - Production Grade",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "npm run dev --workspace @hris/api",
    "dev:web": "npm run dev --workspace @hris/web",
    "dev:all": "npm run infra:up && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "infra:ps": "docker compose -f docker-compose.dev.yml ps",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "prettier": "^3.2.5",
    "turbo": "^1.13.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
