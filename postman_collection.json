    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API is healthy', function() {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.status).to.equal('healthy');",
                  "    pm.expect(response.checks.database).to.equal('healthy');",
                  "    pm.expect(response.checks.redis).to.equal('healthy');",
                  "});"
